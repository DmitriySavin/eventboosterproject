<li class="list-card">
    <img class="card__image" src="{{image}}" alt="{{title}}">
    <div class="card__content">
        <h3 class="card__title">{{title}}</h3>
        <p class="card__date">{{date}}</p>
        <p class="card__location">
            {{!-- <svg class="card__icon" width="14" height="14">
                <use href="../../sprite/place-icon.svg"></use>
            </svg> --}}

            <img src="../images/Vector (1).png" alt="" width="14" height="14">
            {{location}}
        </p>
    </div>
</li>